pipeline {
    agent {
        node {
            label "${AGENT_LABEL}"
        }
    }

    parameters {
        string(
            name: 'AGENT_LABEL',
            defaultValue: 'partner-node',
            description: 'Jenkins node label where this pipeline will run'
        )
        string(
            name: 'DOCKER_TAG',
            defaultValue: 'latest',
            description: 'Image tag from Harbor to deploy (e.g. 0.1.15 or latest)'
        )
    }

    environment {
        APP_NAME         = "cop-pilot-portal"              // same as in docker-compose
        DOCKER_REG       = "harbor.cop-pilot.rid-intrasoft.eu"
        DOCKER_REPO      = "/cop-pilot-portal/"            // Harbor project/repository
        DOCKER_REG_CREDS = "harbor-creds"                  // Jenkins credentials ID
    }

    stages {

        // ******************************
        // *** CHECK ENV / COMPOSE    ***
        // ******************************
        stage("Check_Repo_Layout") {
            steps {
                echo "***** Checking docker-compose.yml and .env *****"
                sh '''
                    set -e
                    if [ ! -f docker-compose.yml ] && [ ! -f compose.yml ] && [ ! -f docker-compose.yaml ]; then
                      echo "ERROR: No docker-compose file found in workspace"
                      exit 1
                    fi

                    if [ ! -f .env ]; then
                      echo "WARNING: .env file is missing in workspace (compose may still use defaults)"
                    else
                      echo ".env file found."
                    fi
                '''
            }
        }

        // ******************************
        // *** PULL IMAGE FROM HARBOR ***
        // ******************************
        stage("Pull_Image_From_Harbor") {
            steps {
                withCredentials([[
                    $class: 'UsernamePasswordMultiBinding',
                    credentialsId: "${DOCKER_REG_CREDS}",
                    usernameVariable: 'USERNAME',
                    passwordVariable: 'PASSWORD'
                ]]) {
                    echo "***** Login to Harbor and pull image *****"
                    sh '''
                        set -e
                        echo "Using image: ${DOCKER_REG}${DOCKER_REPO}${APP_NAME}:${DOCKER_TAG}"
                        docker login ${DOCKER_REG} -u ${USERNAME} -p ${PASSWORD}

                        # Let docker compose resolve the image name using our env vars
                        DOCKER_TAG=${DOCKER_TAG} \
                        DOCKER_REG=${DOCKER_REG} \
                        DOCKER_REPO=${DOCKER_REPO} \
                        APP_NAME=${APP_NAME} \
                        docker compose pull
                    '''
                }
            }
        }

        // **************
        // *** Deploy ***
        // **************
        stage("Deployment") {
            steps {
                echo "***** Deploying portal with docker compose *****"
                sh '''
                    set -e
                    DOCKER_TAG=${DOCKER_TAG} \
                    DOCKER_REG=${DOCKER_REG} \
                    DOCKER_REPO=${DOCKER_REPO} \
                    APP_NAME=${APP_NAME} \
                    docker compose up -d

                    docker ps
                '''
            }
        }

        // ****************************
        // *** Smoke / Health Check ***
        // ****************************
        stage("Smoke_Test") {
            steps {
                echo "***** Running smoke check on port 3000 *****"
                sh '''
                    set -e
                    # Try localhost first; if behind SIF etc, adapt this later
                    echo "Waiting for portal to respond on http://localhost:3000 ..."
                    for i in {1..12}; do
                      if curl -fs http://localhost:3000 > /dev/null 2>&1; then
                        echo "Smoke test OK: portal is responding."
                        exit 0
                      fi
                      echo "Not ready yet, retrying in 5s..."
                      sleep 5
                    done

                    echo "ERROR: portal did not become healthy on http://localhost:3000 in time"
                    exit 1
                '''
            }
        }
    }

    post {
        failure {
            echo "Deployment failed. Showing last logs from docker compose (if available)."
            sh '''
                set +e
                docker compose ps || true
                docker compose logs --tail=100 app || true
            '''
        }
    }
}
