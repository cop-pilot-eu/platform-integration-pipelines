pipeline {
    agent {
        node {
            label "${AGENT_LABEL}"
        }
    }

    parameters {
        string(
            name: 'AGENT_LABEL',
            defaultValue: 'dev00',
            description: 'Jenkins node label where this pipeline will run'
        )
        string(
            name: 'DOCKER_TAG',
            defaultValue: 'latest',
            description: 'Image tag to deploy (e.g. latest, 0.1.5)'
        )
        booleanParam(
            name: 'SEED_ADMIN',
            defaultValue: true,
            description: 'Seed an initial admin user after deployment'
        )
        string(
            name: 'ADMIN_EMAIL',
            defaultValue: 'admin@example.com',
            description: 'Email for the seeded admin user'
        )
        password(
            name: 'ADMIN_PASSWORD',
            defaultValue: 'ChangeMe123!',
            description: 'Password for the seeded admin user'
        )
        string(
            name: 'TMF_BASE_URL',
            defaultValue: '',
            description: 'Base URL of the TM Forum API gateway (optional)'
        )
        string(
            name: 'TMF_API_KEY',
            defaultValue: '',
            description: 'Bearer token for TMF requests (optional)'
        )
        string(
            name: 'LLM_ASSISTANT_ENDPOINT',
            defaultValue: '',
            description: 'External LLM assistant endpoint (optional)'
        )
        password(
            name: 'LLM_ASSISTANT_API_KEY',
            defaultValue: '',
            description: 'Bearer token for the assistant endpoint (optional)'
        )
    }

    environment {
        APP_NAME            = "cop-pilot-portal"
        DOCKER_REG          = "harbor.cop-pilot.rid-intrasoft.eu"
        DOCKER_REPO         = "/cop-pilot-portal/"
        DOCKER_REG_CREDS    = "harbor-creds"
        BETTER_AUTH_SECRET  = credentials('cop-pilot-portal-auth-secret')
        BETTER_AUTH_URL     = "http://localhost:3000"
    }

    stages {

        // **************************
        // *** Pull Image          ***
        // **************************
        stage("Pull_Image") {
            steps {
                withCredentials([[$class: 'UsernamePasswordMultiBinding', credentialsId: "${DOCKER_REG_CREDS}", usernameVariable: 'USERNAME', passwordVariable: 'PASSWORD']]) {
                    echo "***** Pulling ${APP_NAME}:${DOCKER_TAG} from Harbor *****"
                    sh '''
                        set -e
                        docker login ${DOCKER_REG} -u ${USERNAME} -p ${PASSWORD}
                        docker pull ${DOCKER_REG}${DOCKER_REPO}${APP_NAME}:${DOCKER_TAG}
                    '''
                }
            }
        }

        // **************
        // *** Deploy ***
        // **************
        stage("Deployment") {
            steps {
                echo "***** Deploy Application *****"
                sh '''
                    set -e
                    HOST_URL=$(hostname -I | awk '{print $1}')
                    export BETTER_AUTH_URL="http://${HOST_URL}:3000"
                    export TMF_BASE_URL="${TMF_BASE_URL}"
                    export TMF_API_KEY="${TMF_API_KEY}"
                    export LLM_ASSISTANT_ENDPOINT="${LLM_ASSISTANT_ENDPOINT}"
                    export LLM_ASSISTANT_API_KEY="${LLM_ASSISTANT_API_KEY}"
                    docker compose up -d
                    docker ps
                '''
            }
        }

        // ****************************
        // *** Seed initial user    ***
        // ****************************
        stage("Seed_Admin_User") {
            when {
                expression { return params.SEED_ADMIN }
            }
            steps {
                echo "***** Seeding initial admin user via /api/auth/sign-up/email *****"
                sh '''
                    set -e

                    # Wait for portal to be ready
                    for i in $(seq 1 10); do
                        if curl -fs http://localhost:3000 > /dev/null 2>&1; then
                            echo "Portal responding, seeding user..."
                            break
                        fi
                        echo "Waiting for portal on localhost:3000..."
                        sleep 5
                    done

                    STATUS=$(curl -o /tmp/register_resp.txt -s -w "%{http_code}" \
                        -X POST http://localhost:3000/api/auth/sign-up/email \
                        -H "Content-Type: application/json" \
                        -d "{\"name\":\"Admin\",\"email\":\"${ADMIN_EMAIL}\",\"password\":\"${ADMIN_PASSWORD}\"}")

                    if [ "$STATUS" = "200" ] || [ "$STATUS" = "201" ] || [ "$STATUS" = "409" ]; then
                        echo "Seed user request returned HTTP $STATUS (OK or already exists)"
                    else
                        echo "Seed user request returned HTTP $STATUS"
                        cat /tmp/register_resp.txt || true
                        echo "WARNING: Seeding failed, but deployment continues"
                    fi
                '''
            }
        }
    }

    post {
        failure {
            node("${AGENT_LABEL}") {
                sh 'docker compose down || true'
            }
        }
    }
}
